{
  "name": "@labhaus/api",
  "version": "0.1.0",
  "private": true,
  "description": "Labhaus API service",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "migrate": "psql $DATABASE_URL -f migrations/001_create_styles.sql && psql $DATABASE_URL -f migrations/002_create_users.sql",
    "import-styles": "tsx src/scripts/import-styles.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@labhaus/types": "workspace:*",
    "bcrypt": "^5.1.1",
    "hono": "^4.7.9",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.20.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
